# SAFpedia — Environment Variables (example)
# Copy this file to .env and fill in real values. Never commit .env.

# --- Firebase (Auth + Firestore, Spark Plan) ---
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=

# --- Cloudinary (PDF, audio, image storage) ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_UPLOAD_PRESET=

# --- Paystack (payments) ---
PAYSTACK_PUBLIC_KEY=
PAYSTACK_SECRET_KEY=

# --- Admin authorization ---
SUPER_ADMIN_EMAIL=

# --- Email (Firebase Extensions / SendGrid — confirm choice in Milestone 8) ---
SENDGRID_API_KEY=
